{
  "storage_accounts": [
    {
      "name": "storage-prod",
      "allow_blob_public_access": true,
      "supports_https_traffic_only": false,
      "minimum_tls_version": "TLS1_0"
    },
    {
      "name": "storage-logs",
      "allow_blob_public_access": false,
      "supports_https_traffic_only": true,
      "minimum_tls_version": "TLS1_2"
    }
  ],
  "network_security_groups": [
    {
      "name": "nsg-web",
      "rules": [
        {"name": "Allow-SSH-Internet", "source": "0.0.0.0/0", "destination_port": 22, "access": "Allow"},
        {"name": "Allow-HTTPS", "source": "0.0.0.0/0", "destination_port": 443, "access": "Allow"}
      ]
    },
    {
      "name": "nsg-admin",
      "rules": [
        {"name": "Allow-RDP-VPN", "source": "10.20.0.0/16", "destination_port": 3389, "access": "Allow"}
      ]
    }
  ],
  "key_vaults": [
    {"name": "kv-prod", "soft_delete_enabled": true, "purge_protection_enabled": false},
    {"name": "kv-secure", "soft_delete_enabled": true, "purge_protection_enabled": true}
  ],
  "public_ips": [
    {"name": "pip-prod-db", "attached_to": "prod-db-01", "environment": "production", "business_critical": true},
    {"name": "pip-test-web", "attached_to": "test-web-01", "environment": "test", "business_critical": false}
  ],
  "sql_servers": [
    {"name": "sql-prod", "public_network_access": "Enabled", "minimum_tls_version": "1.0", "auditing_enabled": false},
    {"name": "sql-reporting", "public_network_access": "Disabled", "minimum_tls_version": "1.2", "auditing_enabled": true}
  ],
  "app_services": [
    {"name": "app-legacy", "https_only": false, "ftps_state": "AllAllowed", "minimum_tls_version": "1.0"},
    {"name": "app-secure", "https_only": true, "ftps_state": "FtpsOnly", "minimum_tls_version": "1.2"}
  ]
}
